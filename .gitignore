# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go build output
/bin/
/build/
/dist/
/installer/build/
/artifacts-out/

# Per-tier dist/ (relay/, windows/, linux/, android/) — built by their own
# goreleaser configs.
/relay/dist/
/windows/dist/
/linux/dist/
/android/dist/

# Generated by scripts/fetch-wintun.sh — re-created at build time, never edit.
/internal/tun/wintun_dll_windows.go
/windows/internal/tun/wintun_dll_windows.go

# Extensionless binaries (Linux/macOS builds)
/client
/tray
/relay
/portable
/ui
/levoile-*
relay/deploy/relay

# Refacto cross-platform : autoriser les répertoires racine (windows/, linux/, relay/, android/)
# malgré les patterns binaires ci-dessus.
!/relay/
!/client/
!/ui/

# Vendor directory
vendor/

# Test binary
*.test

# Go coverage
*.out
coverage.html

# IDE / CLI config
.idea/
.vscode/
.claude/
*.swp
*.swo
*~

# TLS certificates and private keys
*.pem
# …mais les clés publiques release (story 7.4) sont PUBLIQUES par définition.
!docs/keys/*.pem

# Master signing keys (story 7.4) — la privée ne doit JAMAIS être committée.
# La publique est exposée via internal/crypto/release_keys.go + docs/keys/.
signing.key
signing.key.*
*.signing.key
**/signing.key

# Sauvegardes chiffrées générées par scripts/backup-signing-key.sh
/backup/
**/backup/signing.key.*

# GitHub Personal Access Tokens stockés localement par le mainteneur pour
# lancer des releases depuis la machine de dev. Par convention, un fichier
# par scope/usage, jamais commité.
.github/token-*

# Signature détachée générée au release time par le before.hook goreleaser
# pour install.sh (fix C7 audit). Jamais commitée — re-créée à chaque release
# avec la clé master active.
relay/deploy/install.sh.sig

# Runtime config (may contain credentials)
config.toml
# …mais conserver les skeletons shippés dans les paquets (story 7.2).
!packaging/etc/config.toml
!installer/config-default.toml

# BMAD framework
/_bmad/

# OS files
.DS_Store
Thumbs.db
