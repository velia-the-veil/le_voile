*.exe
*.exe~
*.dll
*.so
*.dylib

# Go build output
/bin/
/build/
/dist/
/installer/build/

# Generated by scripts/fetch-wintun.sh — re-created at build time, never edit.
/internal/tun/wintun_dll_windows.go

# Extensionless binaries (Linux/macOS builds)
/client
/tray
/relay
/portable
/ui
/levoile-*
deploy/relay

# Vendor directory
vendor/

# Test binary
*.test

# Go coverage
*.out
coverage.html

# IDE / CLI config
.idea/
.vscode/
.claude/
*.swp
*.swo
*~

# TLS certificates and private keys
*.pem
# …mais les clés publiques release (story 7.4) sont PUBLIQUES par définition.
!docs/keys/*.pem

# Master signing keys (story 7.4) — la privée ne doit JAMAIS être committée.
# La publique est exposée via internal/crypto/release_keys.go + docs/keys/.
signing.key
signing.key.*
*.signing.key
**/signing.key

# Sauvegardes chiffrées générées par scripts/backup-signing-key.sh
/backup/
**/backup/signing.key.*

# Runtime config (may contain credentials)
config.toml
# …mais conserver les skeletons shippés dans les paquets (story 7.2).
!packaging/etc/config.toml
!installer/config-default.toml

# BMAD framework
/_bmad/

# Browser extension build artifacts
extension.zip
web-ext-artifacts/

# OS files
.DS_Store
Thumbs.db
