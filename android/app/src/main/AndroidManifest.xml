<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- NFR-AND-7 : permissions minimales auditables.
         Aucune permission dangereuse ni non listée.
         BIND_VPN_SERVICE n'est PAS une <uses-permission> mais est attachée
         au tag <service android:permission="android.permission.BIND_VPN_SERVICE" ...>
         de LeVoileVpnService (livré Story 9.4 ci-dessous). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Story 9.4 : Android 14 (API 34) requiert un foregroundServiceType
         déclaré dans le manifest pour tout Foreground Service. AAPT2 build-tools
         34.0.0 N'accepte PAS la valeur littérale "vpn" dans l'enum
         foregroundServiceType (réservée au runtime via setForegroundServiceType
         + ServiceInfo.FOREGROUND_SERVICE_TYPE_VPN). Pattern retenu (cohérent
         architecture.md l. 664-666) : foregroundServiceType="specialUse" +
         <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
         android:value="vpn"/> sur le tag <service>. La permission applicative
         correspondante est FOREGROUND_SERVICE_SPECIAL_USE. BIND_VPN_SERVICE
         (sur le tag <service>) reste le verrou sécurité système. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.LeVoile"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- MainActivity (Story 9.3) : activity unique hôte WebView.
             Décisions architecturales détaillées dans README-android.md
             § « Lancement de l'app debug » et architecture.md l. 1153-1183. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|navigation"
            android:launchMode="singleTop"
            android:theme="@style/Theme.LeVoile">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Story 9.4 : VpnService + Foreground Service "specialUse" subtype "vpn" (Android 14+).
             - android:permission BIND_VPN_SERVICE : seul le système Android peut
               bind ce service (sécurité, architecture.md l. 658).
             - android:foregroundServiceType "specialUse" : AAPT2 build-tools
               34.0.0 n'accepte pas la valeur "vpn" dans l'enum manifest ;
               on déclare specialUse + <property> SUBTYPE "vpn" comme documenté
               architecture.md l. 664-666. La permission applicative
               FOREGROUND_SERVICE_SPECIAL_USE est déclarée plus haut.
             - <property> PROPERTY_SPECIAL_USE_FGS_SUBTYPE "vpn" : précise la
               nature réelle du service (audit NFR-AND-7) — Android 14+ exige
               cette property quand specialUse est utilisé.
             - android:exported false : Android 12+ requiert exported explicite.
             - intent-filter android.net.VpnService : signature standard pour
               qu'Android reconnaisse le service comme implémentation VpnService
               (apparaît dans Réglages → Apps VPN). -->
        <service
            android:name=".vpn.LeVoileVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="vpn" />
        </service>

    </application>
</manifest>
