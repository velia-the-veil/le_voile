<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ : désactive cloud backup et device-to-device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
