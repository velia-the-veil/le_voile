{
  "manifest_version": 2,
  "name": "Le Voile",
  "version": "1.0.0",
  "description": "Optimiseur de connexion et protection en ligne.",
  "permissions": ["proxy", "webRequest", "webRequestBlocking", "downloads", "<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "levoile@plateformeliberte.fr",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "techdata_collected": false,
        "interactiondata_collected": false
      }
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
