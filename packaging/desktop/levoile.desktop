[Desktop Entry]
Type=Application
Version=1.0
Name=Le Voile
GenericName=VPN
Comment=Client VPN Le Voile — tunnel chiffré et kill switch
Comment[fr]=Client VPN Le Voile — tunnel chiffré et kill switch
# Délègue le lancement à systemd --user pour bénéficier de Restart=on-failure
# du unit user levoile-ui.service (story 5.7). Un lancement direct de
# /usr/bin/levoile-ui court-circuiterait cette supervision.
Exec=/bin/sh -c "systemctl --user start levoile-ui.service"
Icon=levoile
Terminal=false
Categories=Network;Security;
Keywords=VPN;privacy;tunnel;proxy;security;
StartupNotify=false
StartupWMClass=levoile-ui
