[Desktop Entry]
Type=Application
Name=Le Voile UI
GenericName=VPN tray applet
Comment=Tray applet for Le Voile VPN (auto-restarts on crash via systemd --user)
# Delegate the actual launch to systemd --user so Restart=on-failure and
# the rate limit kick in. Launching levoile-ui directly here would bypass
# supervision (Story 5.7).
Exec=/bin/sh -c "systemctl --user start levoile-ui.service"
X-GNOME-Autostart-enabled=true
NoDisplay=true
Terminal=false
OnlyShowIn=GNOME;KDE;XFCE;MATE;LXDE;Cinnamon;Unity;Pantheon;Budgie;LXQt;
