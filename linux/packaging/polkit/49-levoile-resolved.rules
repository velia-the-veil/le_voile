// Le Voile VPN — autorise le user système `levoile` à reconfigurer
// systemd-resolved (org.freedesktop.resolve1.*).
//
// Le service tourne en User=levoile (cf. /usr/lib/systemd/system/levoile.service)
// et shell out vers `resolvectl dns <iface> <addr>` pour pointer le DNS
// système vers le proxy local. resolvectl passe par D-Bus → polkit, et
// l'autorisation par défaut requiert un admin authentifié interactivement.
// Pour un service système non-interactif, ça échoue sans cette règle.
//
// Audit fix D2 + D4 (2026-05-04) — scope strict aux cinq actions réellement
// utilisées par le service :
//   - set-link-dns-servers : `resolvectl dns <iface> <addr>`
//   - revert-link          : `resolvectl revert <iface>`
//   - flush-caches         : `resolvectl flush-caches`
//   - set-link-mdns        : `resolvectl mdns <iface> off` (D4 — anti-leak LAN)
//   - set-link-llmnr       : `resolvectl llmnr <iface> off` (D4 — anti-leak LAN)
// Antérieurement la règle ouvrait l'ensemble de org.freedesktop.resolve1.*
// (set-link-default-route, set-link-dnssec, register, etc.), ce qui
// autorisait un attaquant ayant compromis le user `levoile` à désactiver
// DNSSEC partout ou à réenregistrer un nom de service. Le scope est
// désormais minimal et l'usage de mdns/llmnr off est cohérent (on les
// désactive — on ne les active jamais).
//
// Polkit relit ce fichier via inotify dès qu'il apparaît dans
// /etc/polkit-1/rules.d/ → pas de reload requis après installation.
polkit.addRule(function(action, subject) {
    if (subject.user !== "levoile") {
        return;
    }
    if (action.id === "org.freedesktop.resolve1.set-link-dns-servers" ||
        action.id === "org.freedesktop.resolve1.revert-link" ||
        action.id === "org.freedesktop.resolve1.flush-caches" ||
        action.id === "org.freedesktop.resolve1.set-link-mdns" ||
        action.id === "org.freedesktop.resolve1.set-link-llmnr") {
        return polkit.Result.YES;
    }
});
